# Indian Economic Stability API – Environment Variables
# Copy to .env and adjust for production (Render/Railway, Supabase/Neon)

# App
APP_NAME=Economic Stability API
APP_VERSION=2.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite for demo; use PostgreSQL for production)
# DATABASE_URL=sqlite:///./economic_stability.db
# Production example (Neon/Supabase):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Cache (seconds)
MARKET_CACHE_TTL=86400
STABILITY_CACHE_TTL=300

# Scheduler
SCHEDULER_ENABLED=true

# Logging
LOG_LEVEL=INFO
